{
  "name": "conduit-cypress-tests",
  "version": "1.0.0",
  "description": "Automatski testovi za Conduit aplikaciju - Cypress + JavaScript",
  "scripts": {
    "test": "cypress run",
    "test:open": "cypress open",
    "test:report": "cypress run && npm run merge-reports && npm run generate-report",
    "merge-reports": "mochawesome-merge reports/*.json > reports/merged-report.json",
    "generate-report": "marge reports/merged-report.json --reportDir reports/html --inline"
  },
  "devDependencies": {
    "cypress": "^13.9.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0"
  }
}
